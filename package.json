{
  "name": "parable-monorepo",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=packages/api\" \"npm run dev --workspace=packages/web\"",
    "build": "npm run build --workspace=packages/web && npm run build --workspace=packages/api",
    "start": "npm run start --workspace=packages/api",
    "lint": "npm run lint --workspace=packages/web"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
